#!/usr/bin/env bash

set -euo pipefail

source_root=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)

mkdir -p "$source_root/build"

exec cc -std=c11 -O2 -Wall -Wextra -Werror -pedantic \
  "$source_root/helper/cl-exec-sandbox-helper.c" \
  -o "$source_root/build/cl-exec-sandbox-helper"
